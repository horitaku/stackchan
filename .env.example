# Stackchan server local template
APP_ENV=local
SERVER_ADDR=:8080
LOG_LEVEL=info

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_STT=gpt-4o-mini-transcribe

# Voicevox
VOICEVOX_BASE_URL=http://voicevox:50021

# PostgreSQL
DATABASE_URL=postgres://stackchan:change-me@localhost:5432/stackchan?sslmode=disable

# Session
SESSION_SECRET=replace-with-long-random-secret

# WebSocket
WS_READ_TIMEOUT=30
WS_WRITE_TIMEOUT=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

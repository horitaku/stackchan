; Stackchan firmware local template
; Copy to platformio.ini.local and fill your local values.

[env:stackchan_cores3]
platform = espressif32
board = m5stack-cores3
framework = arduino
monitor_speed = 115200

; Local secret file should not be committed.
extra_configs =
  platformio.ini.local

build_flags =
  -DFW_DEVICE_ID=\"stackchan-cores3-01\"
  -DFW_WS_URL=\"ws://127.0.0.1:8080/ws\"
  -DFW_AUDIO_SAMPLE_RATE=16000
  -DFW_AUDIO_FRAME_MS=20
  -DFW_OPUS_BITRATE=24000
  -DFW_LOG_LEVEL=\"info\"
  -DFW_RECONNECT_BASE_MS=500
  -DFW_RECONNECT_MAX_MS=10000
  -DFW_TIMEZONE=\"Asia/Tokyo\"

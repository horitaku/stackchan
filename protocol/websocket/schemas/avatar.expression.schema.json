{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "avatar.expression",
  "description": "アバター表情の更新イベント（server -> firmware）",
  "type": "object",
  "required": ["type", "timestamp", "session_id", "sequence", "version", "payload"],
  "properties": {
    "type": { "const": "avatar.expression" },
    "timestamp": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "version": { "const": "1.0" },
    "payload": { "$ref": "#/definitions/AvatarExpressionPayload" }
  },
  "definitions": {
    "AvatarExpressionPayload": {
      "type": "object",
      "required": ["request_id", "expression"],
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1,
          "description": "対象会話ターンの request_id"
        },
        "expression": {
          "type": "string",
          "enum": ["neutral", "happy", "sad", "surprised"],
          "description": "アバター表情"
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "表情強度（任意）"
        }
      }
    }
  }
}

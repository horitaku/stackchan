{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "device.audio.test.play",
  "description": "スピーカーテスト再生を指示するイベント（server -> firmware）。",
  "type": "object",
  "required": ["type", "timestamp", "session_id", "sequence", "version", "payload"],
  "properties": {
    "type":       { "const": "device.audio.test.play" },
    "timestamp":  { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "sequence":   { "type": "integer", "minimum": 1 },
    "version":    { "const": "1.0" },
    "payload":    { "$ref": "#/definitions/DeviceAudioTestPlayPayload" }
  },
  "additionalProperties": false,
  "definitions": {
    "DeviceAudioTestPlayPayload": {
      "type": "object",
      "required": ["request_id"],
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1,
          "description": "診断・ログ用の相関 ID"
        },
        "tone_hz": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3000,
          "description": "テストトーン周波数（Hz）。省略時は firmware デフォルト"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 5000,
          "description": "再生時間（ms）。省略時は firmware デフォルト"
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "再生音量（0.0〜1.0）。省略時は firmware デフォルト"
        }
      }
    }
  }
}

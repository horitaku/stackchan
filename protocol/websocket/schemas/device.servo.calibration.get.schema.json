{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "device.servo.calibration.get",
  "description": "サーボ校正値の読み出し要求イベント（server -> firmware）。firmware は device.servo.calibration.response を返す。",
  "type": "object",
  "required": ["type", "timestamp", "session_id", "sequence", "version", "payload"],
  "properties": {
    "type":       { "const": "device.servo.calibration.get" },
    "timestamp":  { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "sequence":   { "type": "integer", "minimum": 1 },
    "version":    { "const": "1.0" },
    "payload":    { "$ref": "#/definitions/DeviceServoCalibrationGetPayload" }
  },
  "additionalProperties": false,
  "definitions": {
    "DeviceServoCalibrationGetPayload": {
      "type": "object",
      "required": ["request_id"],
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1,
          "description": "device.servo.calibration.response で返す相関 ID"
        }
      }
    }
  }
}

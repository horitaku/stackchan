{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "device.state.report",
  "description": "ハードウェア診断状態の要求/通知イベント（bidirectional）。server -> firmware は要求、firmware -> server はレポート。",
  "type": "object",
  "required": ["type", "timestamp", "session_id", "sequence", "version", "payload"],
  "properties": {
    "type":       { "const": "device.state.report" },
    "timestamp":  { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "sequence":   { "type": "integer", "minimum": 1 },
    "version":    { "const": "1.0" },
    "payload":    {
      "oneOf": [
        { "$ref": "#/definitions/DeviceStateReportRequestPayload" },
        { "$ref": "#/definitions/DeviceStateReportResponsePayload" }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "DeviceServoAxisCalibration": {
      "type": "object",
      "required": [
        "center_offset_deg",
        "min_deg",
        "max_deg",
        "invert",
        "speed_limit_deg_per_sec",
        "soft_start",
        "home_deg"
      ],
      "additionalProperties": false,
      "properties": {
        "center_offset_deg": { "type": "number", "minimum": -45, "maximum": 45 },
        "min_deg": { "type": "number", "minimum": -90, "maximum": 0 },
        "max_deg": { "type": "number", "minimum": 0, "maximum": 90 },
        "invert": { "type": "boolean" },
        "speed_limit_deg_per_sec": { "type": "number", "minimum": 1, "maximum": 360 },
        "soft_start": { "type": "boolean" },
        "home_deg": { "type": "number", "minimum": -90, "maximum": 90 }
      }
    },
    "DeviceStateReportRequestPayload": {
      "type": "object",
      "required": ["request_id"],
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1,
          "description": "診断要求の相関 ID"
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "要求元識別子（例: webui.hardware_test）"
        }
      }
    },
    "DeviceStateReportResponsePayload": {
      "type": "object",
      "required": [
        "uptime_ms",
        "rssi",
        "free_heap_bytes",
        "current_angle_x_deg",
        "current_angle_y_deg",
        "calibration",
        "mic_level",
        "speaker_busy",
        "camera_available"
      ],
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1,
          "description": "要求イベントと対応づける相関 ID"
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "レポート生成元識別子（例: webui.hardware_test, server.request）"
        },
        "uptime_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "firmware 起動からの経過時間（ms）"
        },
        "rssi": {
          "type": "integer",
          "minimum": -120,
          "maximum": 0,
          "description": "Wi-Fi 信号強度（dBm）"
        },
        "free_heap_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "空きヒープサイズ（bytes）"
        },
        "current_angle_x_deg": {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "現在の X 軸論理角度（度）"
        },
        "current_angle_y_deg": {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "現在の Y 軸論理角度（度）"
        },
        "calibration": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "$ref": "#/definitions/DeviceServoAxisCalibration" },
            "y": { "$ref": "#/definitions/DeviceServoAxisCalibration" }
          }
        },
        "mic_level": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "マイク入力レベル（0.0〜1.0）"
        },
        "speaker_busy": {
          "type": "boolean",
          "description": "スピーカー再生中フラグ"
        },
        "camera_available": {
          "type": "boolean",
          "description": "カメラ利用可否"
        },
        "firmware_version": {
          "type": "string",
          "minLength": 1,
          "description": "firmware バージョン文字列"
        }
      }
    }
  }
}

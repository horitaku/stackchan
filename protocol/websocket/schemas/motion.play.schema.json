{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "motion.play",
  "description": "モーション再生指示イベント（server -> firmware）",
  "type": "object",
  "required": ["type", "timestamp", "session_id", "sequence", "version", "payload"],
  "properties": {
    "type": { "const": "motion.play" },
    "timestamp": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "version": { "const": "1.0" },
    "payload": { "$ref": "#/definitions/MotionPlayPayload" }
  },
  "definitions": {
    "MotionPlayPayload": {
      "type": "object",
      "required": ["request_id", "motion"],
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1,
          "description": "対象会話ターンの request_id"
        },
        "motion": {
          "type": "string",
          "enum": ["idle", "nod", "shake"],
          "description": "モーション名"
        },
        "speed": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 3,
          "description": "再生速度倍率（任意）"
        }
      }
    }
  }
}

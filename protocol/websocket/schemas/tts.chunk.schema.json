{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tts.chunk",
  "description": "TTS 合成音声を server から firmware へ分割送信するイベント",
  "type": "object",
  "required": ["type", "timestamp", "session_id", "sequence", "version", "payload"],
  "properties": {
    "type": { "const": "tts.chunk" },
    "timestamp": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "version": { "const": "1.0" },
    "payload": { "$ref": "#/definitions/TTSChunkPayload" }
  },
  "definitions": {
    "TTSChunkPayload": {
      "type": "object",
      "required": ["request_id", "chunk_index", "total_chunks", "audio_base64"],
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "chunk_index": {
          "type": "integer",
          "minimum": 0
        },
        "total_chunks": {
          "type": "integer",
          "minimum": 1
        },
        "audio_base64": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
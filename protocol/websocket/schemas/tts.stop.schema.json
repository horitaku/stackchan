{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackchan.local/protocol/websocket/schemas/tts.stop.schema.json",
  "allOf": [
    {
      "$ref": "./envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "tts.stop"
        },
        "payload": {
          "type": "object",
          "required": ["reason"],
          "additionalProperties": false,
          "properties": {
            "request_id": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "enum": ["interrupted", "superseded", "timeout", "error", "session_end"]
            },
            "clear_queue": {
              "type": "boolean"
            }
          }
        }
      }
    }
  ]
}